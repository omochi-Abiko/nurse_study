// NurseStudy Database Schema
// Neon PostgreSQL + NextAuth.js + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// NextAuth.js Required Models
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For Credentials provider

  // User Settings
  examDate      DateTime?
  examYear      Int?
  voiceEnabled  Boolean   @default(false)
  voiceRate     Float     @default(1.0)
  voiceAutoPlay Boolean   @default(false)

  // Relations
  accounts        Account[]
  sessions        Session[]
  answers         QuizAnswer[]
  weakQuestions   WeakQuestion[]
  reflections     Reflection[]
  soapRecords     SOAPRecord[]
  facilities      Facility[]
  photoNotes      PhotoNote[]
  customQuestions CustomQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// Quiz & Learning Models
// ==========================================

model QuizAnswer {
  id            String   @id @default(cuid())
  userId        String
  questionId    String
  selectedIndex Int
  isCorrect     Boolean
  category      String?
  answeredAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionId])
  @@index([answeredAt])
}

model WeakQuestion {
  id             String    @id @default(cuid())
  userId         String
  questionId     String
  addedAt        DateTime  @default(now())
  lastReviewedAt DateTime?
  reviewCount    Int       @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
}

// ==========================================
// Reflection & Mood Models
// ==========================================

model Reflection {
  id        String   @id @default(cuid())
  userId    String
  date      String   // YYYY-MM-DD format
  mood      String   // great, good, okay, tired, tough
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// ==========================================
// Practicum / SOAP Models
// ==========================================

model SOAPRecord {
  id         String   @id @default(cuid())
  userId     String
  date       String   // YYYY-MM-DD format
  patientId  String?
  subjective String   @db.Text
  objective  String   @db.Text
  assessment String   @db.Text
  plan       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model Facility {
  id        String   @id @default(cuid())
  userId    String
  name      String
  address   String?
  createdAt DateTime @default(now())

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes FacilityNote[]

  @@index([userId])
}

model FacilityNote {
  id         String   @id @default(cuid())
  facilityId String
  category   String   // rule, tip, warning
  content    String   @db.Text
  createdAt  DateTime @default(now())

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
}

// ==========================================
// Photo Notes & Custom Questions
// ==========================================

model PhotoNote {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  imageUrl  String   // Vercel Blob URL
  tags      String[] // PostgreSQL array
  category  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CustomQuestion {
  id           String   @id @default(cuid())
  userId       String
  text         String   @db.Text
  type         String   // choice, truefalse
  options      String[] // PostgreSQL array
  correctIndex Int
  explanation  String   @db.Text
  category     String
  source       String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
