# ===========================================
# NurseStudy 環境変数
# ===========================================

# Neon Database (PostgreSQL)
# https://console.neon.tech/ でプロジェクト作成後、接続文字列を取得
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# NextAuth.js
# NEXTAUTH_SECRET は `openssl rand -base64 32` で生成
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Google OAuth
# https://console.cloud.google.com/ で OAuth 2.0 クライアントを作成
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Vercel Blob (写真メモ用・オプション)
# https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN="your-blob-token"
